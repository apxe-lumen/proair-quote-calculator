# Mailgun credentials for sending emails from /api/lead.
# In development the route no-ops with a warning if these are unset.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=proairuk.co.uk
MAILGUN_REGION=eu
MAILGUN_FROM=no-reply@proairuk.co.uk

# ProAir team notification email
PROAIR_EMAIL=contact@proairuk.co.uk

# ntfy.sh topic for push notifications (optional).
# ProAir team subscribes to this topic in the ntfy app.
NTFY_TOPIC=
NTFY_TOKEN=
